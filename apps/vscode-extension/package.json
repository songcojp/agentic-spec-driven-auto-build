{
  "name": "specdrive-ide",
  "displayName": "Spec Explore",
  "description": "VSCode-native SpecDrive workbench for Spec documents, Feature Specs, and execution queue state.",
  "version": "0.1.2",
  "publisher": "specdrive",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/songcojp/agentic-spec-driven-auto-build.git"
  },
  "homepage": "https://github.com/songcojp/agentic-spec-driven-auto-build#readme",
  "bugs": {
    "url": "https://github.com/songcojp/agentic-spec-driven-auto-build/issues"
  },
  "type": "commonjs",
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "Other"
  ],
  "files": [
    ".agents/**",
    "out/**",
    "server/**",
    "resources/**",
    "LICENSE",
    "README.md"
  ],
  "activationEvents": [
    "onView:specdrive.specExplorer",
    "onCommand:specdrive.refresh",
    "onCommand:specdrive.registerProject",
    "onCommand:specdrive.openExecutionWorkbench",
    "onCommand:specdrive.openSpecWorkspace",
    "onCommand:specdrive.openFeatureSpec",
    "onCommand:specdrive.openSystemSettings",
    "onLanguage:markdown"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "Spec Explore",
      "properties": {
        "specdrive.controlPlaneUrl": {
          "type": "string",
          "default": "http://127.0.0.1:43117",
          "description": "Preferred SpecDrive Control Plane URL. The extension may use a nearby free port when auto-starting the bundled server."
        },
        "specdrive.serverMode": {
          "type": "string",
          "enum": [
            "auto",
            "external",
            "off"
          ],
          "default": "auto",
          "description": "Controls whether Spec Explore starts the bundled Control Plane server automatically."
        },
        "specdrive.serverPortStart": {
          "type": "number",
          "default": 43117,
          "minimum": 1024,
          "maximum": 65535,
          "description": "First high port to try when auto-starting the bundled Control Plane server."
        },
        "specdrive.serverWorkerMode": {
          "type": "string",
          "enum": [
            "off",
            "embedded",
            "worker-only"
          ],
          "default": "embedded",
          "description": "Scheduler worker mode for the auto-started bundled server."
        },
        "specdrive.serverNodePath": {
          "type": "string",
          "default": "",
          "description": "Optional Node.js executable path for the bundled server. Empty uses VSCode's extension host executable in Node mode."
        },
        "specdrive.openSpecWorkspaceOnStartup": {
          "type": "boolean",
          "default": false,
          "description": "Open the Spec Workspace webview after the Spec Explore view activates and the Control Plane is ready."
        },
        "specdrive.productConsoleUrl": {
          "type": "string",
          "default": "http://127.0.0.1:45173",
          "description": "Local SpecDrive Product Console URL."
        }
      }
    },
    "commands": [
      {
        "command": "specdrive.refresh",
        "title": "SpecDrive: Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "specdrive.registerProject",
        "title": "SpecDrive: Register Project",
        "icon": "$(repo)"
      },
      {
        "command": "specdrive.filterQueue",
        "title": "SpecDrive: Filter Task Queue"
      },
      {
        "command": "specdrive.openProductConsole",
        "title": "SpecDrive: Open Product Console"
      },
      {
        "command": "specdrive.openExecutionWorkbench",
        "title": "SpecDrive: Open Execution Workbench",
        "icon": "$(run-all)"
      },
      {
        "command": "specdrive.openSpecWorkspace",
        "title": "SpecDrive: Open Spec Workspace",
        "icon": "$(checklist)"
      },
      {
        "command": "specdrive.openFeatureSpec",
        "title": "SpecDrive: Open Feature Spec",
        "icon": "$(layout)"
      },
      {
        "command": "specdrive.openSystemSettings",
        "title": "SpecDrive: Open System Settings",
        "icon": "$(settings-gear)"
      },
      {
        "command": "specdrive.openItem",
        "title": "SpecDrive: Open Item"
      },
      {
        "command": "specdrive.runControlledCommand",
        "title": "SpecDrive: Run Controlled Command"
      },
      {
        "command": "specdrive.openExecution",
        "title": "SpecDrive: Open Execution"
      },
      {
        "command": "specdrive.queueRunNow",
        "title": "SpecDrive: Run Now"
      },
      {
        "command": "specdrive.queuePause",
        "title": "SpecDrive: Pause"
      },
      {
        "command": "specdrive.queueResume",
        "title": "SpecDrive: Resume"
      },
      {
        "command": "specdrive.queueRetry",
        "title": "SpecDrive: Retry"
      },
      {
        "command": "specdrive.queueCancel",
        "title": "SpecDrive: Cancel"
      },
      {
        "command": "specdrive.queueSkip",
        "title": "SpecDrive: Skip"
      },
      {
        "command": "specdrive.queueReprioritize",
        "title": "SpecDrive: Reprioritize"
      },
      {
        "command": "specdrive.approveAccept",
        "title": "SpecDrive: Accept Approval"
      },
      {
        "command": "specdrive.approveAcceptForSession",
        "title": "SpecDrive: Accept Approval for Session"
      },
      {
        "command": "specdrive.approveDecline",
        "title": "SpecDrive: Decline Approval"
      },
      {
        "command": "specdrive.approveCancel",
        "title": "SpecDrive: Cancel Approval"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "specdrive.openSpecWorkspace",
          "when": "view == specdrive.specExplorer",
          "group": "navigation@1"
        },
        {
          "command": "specdrive.openFeatureSpec",
          "when": "view == specdrive.specExplorer",
          "group": "navigation@2"
        },
        {
          "command": "specdrive.openExecutionWorkbench",
          "when": "view == specdrive.specExplorer",
          "group": "navigation@3"
        },
        {
          "command": "specdrive.openSystemSettings",
          "when": "view == specdrive.specExplorer",
          "group": "navigation@4"
        },
        {
          "command": "specdrive.refresh",
          "when": "view == specdrive.specExplorer",
          "group": "navigation@5"
        },
        {
          "command": "specdrive.registerProject",
          "when": "view == specdrive.specExplorer",
          "group": "navigation@6"
        }
      ],
      "view/item/context": [
        {
          "command": "specdrive.openFeatureSpec",
          "when": "view == specdrive.specExplorer && viewItem == feature",
          "group": "navigation@0"
        },
        {
          "command": "specdrive.openExecutionWorkbench",
          "when": "view == specdrive.specExplorer && viewItem =~ /queue-item/",
          "group": "navigation@0"
        },
        {
          "command": "specdrive.openProductConsole",
          "when": "view == specdrive.specExplorer && viewItem =~ /(queue-item|feature)/",
          "group": "navigation@1"
        },
        {
          "command": "specdrive.queueRunNow",
          "when": "view == specdrive.specExplorer && viewItem =~ /queue-item/",
          "group": "queue@1"
        },
        {
          "command": "specdrive.queuePause",
          "when": "view == specdrive.specExplorer && viewItem =~ /queue-item:(queued|running)/",
          "group": "queue@2"
        },
        {
          "command": "specdrive.queueResume",
          "when": "view == specdrive.specExplorer && viewItem =~ /queue-item:(paused|blocked|approval_needed)/",
          "group": "queue@3"
        },
        {
          "command": "specdrive.queueRetry",
          "when": "view == specdrive.specExplorer && viewItem =~ /queue-item:(failed|blocked|cancelled|skipped)/",
          "group": "queue@4"
        },
        {
          "command": "specdrive.queueCancel",
          "when": "view == specdrive.specExplorer && viewItem =~ /queue-item:(queued|running|approval_needed|paused)/",
          "group": "queue@5"
        },
        {
          "command": "specdrive.queueSkip",
          "when": "view == specdrive.specExplorer && viewItem =~ /queue-item:(queued|blocked|failed|paused)/",
          "group": "queue@6"
        },
        {
          "command": "specdrive.queueReprioritize",
          "when": "view == specdrive.specExplorer && viewItem =~ /queue-item:(queued|paused)/",
          "group": "queue@7"
        },
        {
          "command": "specdrive.approveAccept",
          "when": "view == specdrive.specExplorer && viewItem =~ /queue-item:approval_needed/",
          "group": "approval@1"
        },
        {
          "command": "specdrive.approveAcceptForSession",
          "when": "view == specdrive.specExplorer && viewItem =~ /queue-item:approval_needed/",
          "group": "approval@2"
        },
        {
          "command": "specdrive.approveDecline",
          "when": "view == specdrive.specExplorer && viewItem =~ /queue-item:approval_needed/",
          "group": "approval@3"
        },
        {
          "command": "specdrive.approveCancel",
          "when": "view == specdrive.specExplorer && viewItem =~ /queue-item:approval_needed/",
          "group": "approval@4"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "specdrive",
          "title": "Spec Explore",
          "icon": "resources/spec-explore.svg"
        }
      ]
    },
    "views": {
      "specdrive": [
        {
          "id": "specdrive.specExplorer",
          "name": "Spec Explore"
        }
      ]
    }
  }
}
